{
  "name": "telegram-video-file-bot",
  "version": "1.0.0",
  "description": "Telegram bot that returns video links as original-quality documents",
  "main": "dist/app.js",
  "scripts": {
    "dev": "tsx watch src/app.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/app.js",
    "type-check": "tsc --noEmit",
    "lint": "echo 'No lint configured yet'",
    "deploy:server": "bash scripts/server-bootstrap.sh"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "axios": "^1.9.0",
    "bullmq": "^5.56.0",
    "dotenv": "^16.5.0",
    "ioredis": "^5.6.1",
    "p-queue": "^8.0.1",
    "pino": "^9.3.2",
    "telegraf": "^4.16.3"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "typescript": "^5.8.3",
    "tsx": "^4.19.4"
  }
}
